/// Serie de comprobante electrónico.
///
/// `aplicaA` discrimina el subtipo cuando `tipoCpe` es uno transversal (NC, ND
/// que aplican sobre factura o boleta). Para factura/boleta normales, `aplicaA`
/// es null. Reglas:
///   - tipoCpe in {nota_credito, nota_debito} → aplicaA in {factura, boleta} (obligatorio)
///   - tipoCpe in {factura, boleta, guia_*}    → aplicaA es null
///
/// Unicidad: existe a lo sumo UNA fila por (sucursalId, tipoCpe, aplicaA).
/// Una vez creada, la serie es inmutable (no se desactiva, no se borra — regla
/// fiscal). Implementado en DB con dos UNIQUE PARTIAL INDEX (uno para
/// aplica_a NULL, otro para NOT NULL).
model SerieCpe {
  id                String   @id @default(uuid()) @db.Uuid
  sucursalId        String   @map("sucursal_id") @db.Uuid
  sucursal          Sucursal @relation(fields: [sucursalId], references: [id])
  tipoCpe           TipoCpe  @map("tipo_cpe")
  aplicaA           TipoCpe? @map("aplica_a")
  serie             String   @db.VarChar(4)
  correlativoActual Int      @default(0) @map("correlativo_actual")
  creadoEn          DateTime @default(now()) @map("creado_en")
  actualizadoEn     DateTime @updatedAt @map("actualizado_en")

  ventas       Venta[]
  notasCredito NotaCredito[]

  @@index([sucursalId, tipoCpe, aplicaA])
  @@map("series_cpe")
}

model DocumentoElectronico {
  id String @id @default(uuid()) @db.Uuid

  ventaId       String?      @unique @map("venta_id") @db.Uuid
  venta         Venta?       @relation(fields: [ventaId], references: [id])
  notaCreditoId String?      @unique @map("nota_credito_id") @db.Uuid
  notaCredito   NotaCredito? @relation(fields: [notaCreditoId], references: [id])

  tipoCpe     TipoCpe @map("tipo_cpe")
  serie       String  @db.VarChar(4)
  correlativo String  @db.VarChar(8)

  estadoSunat  EstadoSunat @default(pendiente) @map("estado_sunat")
  codigoHash   String?     @map("codigo_hash") @db.VarChar(200)
  cadenaQr     String?     @map("cadena_qr") @db.Text
  mensajeSunat String?     @map("mensaje_sunat") @db.Text

  xmlEnviadoUrl String? @map("xml_enviado_url") @db.VarChar(500)
  cdrUrl        String? @map("cdr_url") @db.VarChar(500)
  pdfUrl        String? @map("pdf_url") @db.VarChar(500)

  numIntentos      Int       @default(0) @map("num_intentos")
  ultimoErrorTexto String?   @map("ultimo_error_texto") @db.Text
  enviadoEn        DateTime? @map("enviado_en")
  aceptadoEn       DateTime? @map("aceptado_en")

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@unique([tipoCpe, serie, correlativo])
  @@index([estadoSunat])
  @@map("documentos_electronicos")
}

model ConfiguracionFacturacion {
  id String @id @default(uuid()) @db.Uuid

  mifactTokenCifrado String @map("mifact_token_cifrado") @db.Text
  mifactBaseUrl      String @default("https://demo.mifact.net.pe/api") @map("mifact_base_url") @db.VarChar(200)

  ruc                String  @db.VarChar(11)
  razonSocial        String  @map("razon_social") @db.VarChar(200)
  nombreComercial    String? @map("nombre_comercial") @db.VarChar(200)
  direccionFiscal    String  @map("direccion_fiscal") @db.VarChar(240)
  ubigeoFiscalCodigo String  @map("ubigeo_fiscal_codigo") @db.VarChar(6)

  enviarAutomaticoASunat Boolean @default(true) @map("enviar_automatico_a_sunat")
  retornarPdf            Boolean @default(true) @map("retornar_pdf")
  retornarXmlEnvio       Boolean @default(false) @map("retornar_xml_envio")
  retornarXmlCdr         Boolean @default(false) @map("retornar_xml_cdr")
  formatoImpresion       String  @default("001") @map("formato_impresion") @db.VarChar(3)

  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("configuracion_facturacion")
}
