  entidadId String?  @map("entidad_id") @db.Uuid
  usuarioId String?  @map("usuario_id") @db.Uuid
  cambios   Json?
  ip        String?  @db.VarChar(45)
  creadoEn  DateTime @default(now()) @map("creado_en")

  @@index([modulo, creadoEn])
  @@map("audit_log")
}

