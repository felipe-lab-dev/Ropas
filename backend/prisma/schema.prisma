// Schema Prisma multi-tenant para Ropas
//
// Estrategia: TODOS los modelos viven sin `@@schema(...)`. El schema real se
// resuelve por search_path vía DATABASE_URL `?schema=...`:
//   - PrismaPublicService → `?schema=public`     → opera sobre Tenant, TenantAudit
//   - PrismaTenantService → `?schema=tenant_<code>` → opera sobre productos, ventas, etc.
//
// Esto permite que un mismo PrismaClient generado se use contra schemas distintos
// dinámicamente. Las queries van sin prefijo de schema y Postgres las resuelve
// según search_path.
//
// `prisma db push` solo aplica al schema `public` por defecto; los schemas de
// tenant se crean vía `scripts/crear-tenant.ts` que ejecuta DDL directamente.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────
// METADATA GLOBAL — vive en schema `public`
// ─────────────────────────────────────────────────────────────────────

enum TenantEstado {
  trial
  activo
  suspendido
  cancelado

  @@map("tenant_estado")
}

model Tenant {
  id                 String       @id @default(uuid()) @db.Uuid
  codigo             String       @unique @db.VarChar(64)
  nombre             String       @db.VarChar(160)
  schemaName         String       @unique @map("schema_name") @db.VarChar(80)
  estado             TenantEstado @default(trial)
  enkiSistemaId      String?      @map("enki_sistema_id") @db.Uuid
  planNombre         String?      @map("plan_nombre") @db.VarChar(80)
  modulosHabilitados Json         @default("[]") @map("modulos_habilitados")
  limites            Json         @default("{}")
  configCache        Json?        @map("config_cache")
  configCacheAt      DateTime?    @map("config_cache_at")
  creadoEn           DateTime     @default(now()) @map("creado_en")
  actualizadoEn      DateTime     @updatedAt @map("actualizado_en")
  eliminadoEn        DateTime?    @map("eliminado_en")

  @@map("tenants")
}

model TenantAudit {
  id       BigInt   @id @default(autoincrement())
  tenantId String?  @map("tenant_id") @db.Uuid
  evento   String   @db.VarChar(80)
  actor    String?  @db.VarChar(160)
  detalles Json?
  creadoEn DateTime @default(now()) @map("creado_en")

  @@index([tenantId, creadoEn])
  @@map("tenant_audit")
}

// ─────────────────────────────────────────────────────────────────────
// DATOS POR TENANT — viven en schema `tenant_<code>`
// El cliente Prisma del tenant ejecuta queries sin prefijo;
// Postgres resuelve vía search_path.
// ─────────────────────────────────────────────────────────────────────

model Usuario {
  id              String    @id @default(uuid()) @db.Uuid
  nombre          String    @db.VarChar(120)
  email           String    @unique @db.VarChar(160)
  dni             String?   @unique @db.VarChar(20)
  passwordHash    String    @map("password_hash") @db.VarChar(120)
  rolId           String    @map("rol_id") @db.Uuid
  rol             Rol       @relation(fields: [rolId], references: [id])
  sucursalDefecto String?   @map("sucursal_defecto") @db.Uuid
  activo          Boolean   @default(true)
  ultimoIngreso   DateTime? @map("ultimo_ingreso")
  preferenciasUi  Json      @default("{}") @map("preferencias_ui")
  creadoEn        DateTime  @default(now()) @map("creado_en")
  actualizadoEn   DateTime  @updatedAt @map("actualizado_en")
  eliminadoEn     DateTime? @map("eliminado_en")

  ventas               Venta[]
  sesionesCaja         SesionCaja[]
  movimientosCaja      MovimientoCaja[] @relation("MovimientosCajaCreados")
  cuponesCreados       Cupon[]          @relation("CuponesCreados")
  notasCreditoEmitidas NotaCredito[]

  @@index([eliminadoEn])
  @@map("usuarios")
}

model Rol {
  id            String    @id @default(uuid()) @db.Uuid
  nombre        String    @unique @db.VarChar(80)
  descripcion   String?   @db.VarChar(240)
  permisos      String[]  @default([])
  esSistema     Boolean   @default(false) @map("es_sistema")
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")
  eliminadoEn   DateTime? @map("eliminado_en")

  usuarios Usuario[]

  @@map("roles")
}

model Sucursal {
  id               String    @id @default(uuid()) @db.Uuid
  codigo           String    @unique @db.VarChar(20)
  nombre           String    @db.VarChar(120)
  direccion        String?   @db.VarChar(240)
  direccionFiscal  String?   @map("direccion_fiscal") @db.VarChar(240)
  ubigeoCodigo     String?   @map("ubigeo_codigo") @db.VarChar(6)
  codigoAnexoSunat String    @default("0000") @map("codigo_anexo_sunat") @db.VarChar(4)
  telefono         String?   @db.VarChar(40)
  esPrincipal      Boolean   @default(false) @map("es_principal")
  activa           Boolean   @default(true)
  creadoEn         DateTime  @default(now()) @map("creado_en")
  actualizadoEn    DateTime  @updatedAt @map("actualizado_en")
  eliminadoEn      DateTime? @map("eliminado_en")

  inventarios  StockSucursal[]
  ventas       Venta[]
  sesionesCaja SesionCaja[]
  compras      Compra[]
  notasCredito NotaCredito[]
  seriesCpe    SerieCpe[]

  @@map("sucursales")
}

model Categoria {
  id            String      @id @default(uuid()) @db.Uuid
  nombre        String      @unique @db.VarChar(80)
  slug          String      @unique @db.VarChar(80)
  padreId       String?     @map("padre_id") @db.Uuid
  padre         Categoria?  @relation("CategoriaJerarquia", fields: [padreId], references: [id])
  hijos         Categoria[] @relation("CategoriaJerarquia")
  orden         Int         @default(0)
  icono         String?     @db.VarChar(40)
  creadoEn      DateTime    @default(now()) @map("creado_en")
  actualizadoEn DateTime    @updatedAt @map("actualizado_en")
  eliminadoEn   DateTime?   @map("eliminado_en")

  productos Producto[]

  @@map("categorias")
}

model Marca {
  id            String    @id @default(uuid()) @db.Uuid
  nombre        String    @unique @db.VarChar(80)
  logoUrl       String?   @map("logo_url") @db.VarChar(240)
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")
  eliminadoEn   DateTime? @map("eliminado_en")

  productos Producto[]

  @@map("marcas")
}

enum Genero {
  hombre
  mujer
  ninio
  ninia
  unisex

  @@map("genero")
}

enum ClasificacionAbc {
  AA
  A
  B
  C
  D

  @@map("clasificacion_abc")
}

enum Temporada {
  primavera
  verano
  otonio
  invierno
  todo_el_anio

  @@map("temporada")
}

model Producto {
  id                 String            @id @default(uuid()) @db.Uuid
  sku                String            @unique @db.VarChar(40)
  codigo             String?           @unique @db.VarChar(40)
  nombre             String            @db.VarChar(160)
  descripcion        String?           @db.Text
  categoriaId        String            @map("categoria_id") @db.Uuid
  categoria          Categoria         @relation(fields: [categoriaId], references: [id])
  marcaId            String?           @map("marca_id") @db.Uuid
  marca              Marca?            @relation(fields: [marcaId], references: [id])
  genero             Genero            @default(unisex)
  temporada          Temporada         @default(todo_el_anio)
  material           String?           @db.VarChar(120)
  cuidado            String?           @db.VarChar(240)
  precioVenta        Decimal           @map("precio_venta") @db.Decimal(12, 2)
  precioCompra       Decimal?          @map("precio_compra") @db.Decimal(12, 2)
  unidadMedidaCodigo String?           @default("NIU") @map("unidad_medida_codigo") @db.VarChar(10)
  tipoAfectacionIgv  TipoAfectacionIgv @default(gravado_onerosa) @map("tipo_afectacion_igv")
  imagenes           String[]          @default([])
  tags               String[]          @default([])
  activo             Boolean           @default(true)
  clasificacion      ClasificacionAbc? @map("clasificacion")
  clasificacionScore Decimal?          @map("clasificacion_score") @db.Decimal(12, 4)
  clasificadoEn      DateTime?         @map("clasificado_en")
  creadoEn           DateTime          @default(now()) @map("creado_en")
  actualizadoEn      DateTime          @updatedAt @map("actualizado_en")
  eliminadoEn        DateTime?         @map("eliminado_en")

  variantes Variante[]

  @@index([eliminadoEn])
  @@index([categoriaId])
  @@map("productos")
}

model Variante {
  id            String    @id @default(uuid()) @db.Uuid
  productoId    String    @map("producto_id") @db.Uuid
  producto      Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  sku           String    @unique @db.VarChar(48)
  talla         String    @db.VarChar(16)
  color         String    @db.VarChar(40)
  colorHex      String?   @map("color_hex") @db.VarChar(7)
  codigoBarras  String?   @unique @map("codigo_barras") @db.VarChar(40)
  precioVenta   Decimal?  @map("precio_venta") @db.Decimal(12, 2)
  pesoGramos    Int?      @map("peso_gramos")
  imagenes      String[]  @default([])
  activo        Boolean   @default(true)
  creadoEn      DateTime  @default(now()) @map("creado_en")
  actualizadoEn DateTime  @updatedAt @map("actualizado_en")
  eliminadoEn   DateTime? @map("eliminado_en")

  stocks            StockSucursal[]
  movimientos       MovimientoStock[]
  ventaItems        VentaItem[]
  compraItems       CompraItem[]
  notasCreditoItems NotaCreditoItem[]

  @@unique([productoId, talla, color])
  @@index([eliminadoEn])
  @@map("variantes")
}

model StockSucursal {
  id            String   @id @default(uuid()) @db.Uuid
  varianteId    String   @map("variante_id") @db.Uuid
  variante      Variante @relation(fields: [varianteId], references: [id], onDelete: Cascade)
  sucursalId    String   @map("sucursal_id") @db.Uuid
  sucursal      Sucursal @relation(fields: [sucursalId], references: [id])
  disponible    Int      @default(0)
  reservado     Int      @default(0)
  enRevision    Int      @default(0) @map("en_revision")
  danado        Int      @default(0)
  stockMinimo   Int      @default(0) @map("stock_minimo")
  ubicacion     String?  @db.VarChar(40)
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@unique([varianteId, sucursalId])
  @@index([sucursalId])
  @@map("stock_sucursales")
}

enum TipoMovimientoStock {
  ingreso_compra
  ingreso_devolucion
  ingreso_ajuste
  egreso_venta
  egreso_merma
  egreso_ajuste
  traslado_salida
  traslado_entrada

  @@map("tipo_movimiento_stock")
}

model MovimientoStock {
  id             String              @id @default(uuid()) @db.Uuid
  varianteId     String              @map("variante_id") @db.Uuid
  variante       Variante            @relation(fields: [varianteId], references: [id])
  sucursalId     String              @map("sucursal_id") @db.Uuid
  tipo           TipoMovimientoStock
  cantidad       Int
  stockAntes     Int                 @map("stock_antes")
  stockDespues   Int                 @map("stock_despues")
  referenciaTipo String?             @map("referencia_tipo") @db.VarChar(40)
  referenciaId   String?             @map("referencia_id") @db.Uuid
  notas          String?             @db.Text
  usuarioId      String?             @map("usuario_id") @db.Uuid
  creadoEn       DateTime            @default(now()) @map("creado_en")

  @@index([varianteId, creadoEn])
  @@index([referenciaTipo, referenciaId])
  @@map("movimientos_stock")
}

enum TipoDocumento {
  dni // SUNAT 1
  carne_extranjeria // SUNAT 4
  ruc // SUNAT 6
  pasaporte // SUNAT 7
  otro // SUNAT 0

  @@map("tipo_documento")
}

model Cliente {
  id                 String            @id @default(uuid()) @db.Uuid
  tipoDocumento      TipoDocumento     @default(dni) @map("tipo_documento")
  documento          String?           @db.VarChar(20)
  nombre             String            @db.VarChar(160)
  email              String?           @db.VarChar(160)
  telefono           String?           @db.VarChar(40)
  direccion          String?           @db.VarChar(240)
  ciudad             String?           @db.VarChar(120)
  ubigeoCodigo       String?           @map("ubigeo_codigo") @db.VarChar(6)
  fechaNacimiento    DateTime?         @map("fecha_nacimiento") @db.Date
  notas              String?           @db.Text
  totalCompras       Decimal           @default(0) @map("total_compras") @db.Decimal(12, 2)
  ultimaCompraEn     DateTime?         @map("ultima_compra_en")
  tags               String[]          @default([])
  clasificacion      ClasificacionAbc?
  clasificacionScore Decimal?          @map("clasificacion_score") @db.Decimal(12, 4)
  clasificadoEn      DateTime?         @map("clasificado_en")
  creadoEn           DateTime          @default(now()) @map("creado_en")
  actualizadoEn      DateTime          @updatedAt @map("actualizado_en")
  eliminadoEn        DateTime?         @map("eliminado_en")

  ventas       Venta[]
  cuponesUsos  CuponUso[]
  notasCredito NotaCredito[]

  @@unique([tipoDocumento, documento])
  @@index([eliminadoEn])
  @@index([clasificacion])
  @@map("clientes")
}

enum EstadoVenta {
  borrador
  confirmada
  pagada
  parcial
  anulada

  @@map("estado_venta")
}

enum MedioPago {
  efectivo
  tarjeta_debito
  tarjeta_credito
  pix
  transferencia
  yape
  plin
  otro

  @@map("medio_pago")
}

model Venta {
  id                       String      @id @default(uuid()) @db.Uuid
  numero                   String      @unique @db.VarChar(20)
  sucursalId               String      @map("sucursal_id") @db.Uuid
  sucursal                 Sucursal    @relation(fields: [sucursalId], references: [id])
  clienteId                String?     @map("cliente_id") @db.Uuid
  cliente                  Cliente?    @relation(fields: [clienteId], references: [id])
  vendedorId               String      @map("vendedor_id") @db.Uuid
  vendedor                 Usuario     @relation(fields: [vendedorId], references: [id])
  estado                   EstadoVenta @default(confirmada)
  subtotal                 Decimal     @db.Decimal(12, 2)
  descuento                Decimal     @default(0) @db.Decimal(12, 2)
  descuentoCupon           Decimal     @default(0) @map("descuento_cupon") @db.Decimal(12, 2)
  cuponId                  String?     @map("cupon_id") @db.Uuid
  cupon                    Cupon?      @relation(fields: [cuponId], references: [id])
  cuponCodigo              String?     @map("cupon_codigo") @db.VarChar(40)
  impuestos                Decimal     @default(0) @db.Decimal(12, 2)
  total                    Decimal     @db.Decimal(12, 2)
  totalPagado              Decimal     @default(0) @map("total_pagado") @db.Decimal(12, 2)
  notas                    String?     @db.Text
  sesionCajaId             String?     @map("sesion_caja_id") @db.Uuid
  sesionCaja               SesionCaja? @relation(fields: [sesionCajaId], references: [id])
  tipoCpe                  TipoCpe?    @map("tipo_cpe")
  serieCpeId               String?     @map("serie_cpe_id") @db.Uuid
  serieCpe                 SerieCpe?   @relation(fields: [serieCpeId], references: [id])
  correlativo              String?     @db.VarChar(8)
  /// Si true, la venta es interna y NO se envía a SUNAT. Excluyente con tipoCpe (CHECK constraint en DB).
  esNotaDeVenta            Boolean     @default(false) @map("es_nota_de_venta")
  moneda                   String      @default("PEN") @db.VarChar(3)
  tipoCambio               Decimal     @default(1) @map("tipo_cambio") @db.Decimal(10, 4)
  fechaVencimiento         DateTime?   @map("fecha_vencimiento") @db.Date
  codigoTipoOperacionSunat String      @default("0101") @map("codigo_tipo_operacion_sunat") @db.VarChar(4)
  anuladaEn                DateTime?   @map("anulada_en")
  motivoAnulacion          String?     @map("motivo_anulacion") @db.Text
  creadoEn                 DateTime    @default(now()) @map("creado_en")
  actualizadoEn            DateTime    @updatedAt @map("actualizado_en")
  eliminadoEn              DateTime?   @map("eliminado_en")

  items                VentaItem[]
  pagos                VentaPago[]
  cuponUso             CuponUso?
  notasCredito         NotaCredito[]
  documentoElectronico DocumentoElectronico?

  @@unique([tipoCpe, serieCpeId, correlativo])
  @@index([sucursalId, creadoEn])
  @@index([clienteId])
  @@index([cuponId])
  @@index([eliminadoEn])
  @@map("ventas")
}

model VentaItem {
  id             String   @id @default(uuid()) @db.Uuid
  ventaId        String   @map("venta_id") @db.Uuid
  venta          Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  varianteId     String   @map("variante_id") @db.Uuid
  variante       Variante @relation(fields: [varianteId], references: [id])
  descripcion    String   @db.VarChar(240)
  cantidad       Int
  precioUnitario Decimal  @map("precio_unitario") @db.Decimal(12, 2)
  descuento      Decimal  @default(0) @db.Decimal(12, 2)
  subtotal       Decimal  @db.Decimal(12, 2)

  notasCreditoItems NotaCreditoItem[]

  @@index([ventaId])
  @@map("venta_items")
}

enum EstadoNotaCredito {
  emitida
  anulada

  @@map("estado_nota_credito")
}

model NotaCredito {
  id                     String            @id @default(uuid()) @db.Uuid
  numero                 String            @unique @db.VarChar(20)
  ventaId                String            @map("venta_id") @db.Uuid
  venta                  Venta             @relation(fields: [ventaId], references: [id])
  sucursalId             String            @map("sucursal_id") @db.Uuid
  sucursal               Sucursal          @relation(fields: [sucursalId], references: [id])
  clienteId              String?           @map("cliente_id") @db.Uuid
  cliente                Cliente?          @relation(fields: [clienteId], references: [id])
  emitidaPorId           String            @map("emitida_por_id") @db.Uuid
  emitidaPor             Usuario           @relation(fields: [emitidaPorId], references: [id])
  estado                 EstadoNotaCredito @default(emitida)
  motivo                 String            @db.Text
  codigoTipoNc           TipoNotaCredito   @default(devolucion_total) @map("codigo_tipo_nc")
  tipoCpeOriginal        TipoCpe?          @map("tipo_cpe_original")
  serieCpeOriginal       String?           @map("serie_cpe_original") @db.VarChar(4)
  correlativoCpeOriginal String?           @map("correlativo_cpe_original") @db.VarChar(8)
  tipoCpe                TipoCpe?          @map("tipo_cpe")
  serieCpeId             String?           @map("serie_cpe_id") @db.Uuid
  serieCpe               SerieCpe?         @relation(fields: [serieCpeId], references: [id])
  correlativo            String?           @db.VarChar(8)
  subtotal               Decimal           @db.Decimal(12, 2)
  total                  Decimal           @db.Decimal(12, 2)
  restituyeStock         Boolean           @default(true) @map("restituye_stock")
  anuladaEn              DateTime?         @map("anulada_en")
  motivoAnulacion        String?           @map("motivo_anulacion") @db.Text
  creadoEn               DateTime          @default(now()) @map("creado_en")
  actualizadoEn          DateTime          @updatedAt @map("actualizado_en")
  eliminadoEn            DateTime?         @map("eliminado_en")

  items                NotaCreditoItem[]
  documentoElectronico DocumentoElectronico?

  @@index([ventaId])
  @@index([clienteId])
  @@index([eliminadoEn])
  @@map("notas_credito")
}

model NotaCreditoItem {
  id             String      @id @default(uuid()) @db.Uuid
  notaCreditoId  String      @map("nota_credito_id") @db.Uuid
  notaCredito    NotaCredito @relation(fields: [notaCreditoId], references: [id], onDelete: Cascade)
  ventaItemId    String      @map("venta_item_id") @db.Uuid
  ventaItem      VentaItem   @relation(fields: [ventaItemId], references: [id])
  varianteId     String      @map("variante_id") @db.Uuid
  variante       Variante    @relation(fields: [varianteId], references: [id])
  descripcion    String      @db.VarChar(240)
  cantidad       Int
  precioUnitario Decimal     @map("precio_unitario") @db.Decimal(12, 2)
  subtotal       Decimal     @db.Decimal(12, 2)

  @@index([notaCreditoId])
  @@index([ventaItemId])
  @@map("notas_credito_items")
}

model VentaPago {
  id         String    @id @default(uuid()) @db.Uuid
  ventaId    String    @map("venta_id") @db.Uuid
  venta      Venta     @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  medio      MedioPago
  monto      Decimal   @db.Decimal(12, 2)
  referencia String?   @db.VarChar(120)
  recibidoEn DateTime  @default(now()) @map("recibido_en")

  @@index([ventaId])
  @@map("venta_pagos")
}

enum EstadoSesionCaja {
  abierta
  cerrada
  con_diferencia

  @@map("estado_sesion_caja")
}

model SesionCaja {
  id            String           @id @default(uuid()) @db.Uuid
  sucursalId    String           @map("sucursal_id") @db.Uuid
  sucursal      Sucursal         @relation(fields: [sucursalId], references: [id])
  cajeroId      String           @map("cajero_id") @db.Uuid
  cajero        Usuario          @relation(fields: [cajeroId], references: [id])
  estado        EstadoSesionCaja @default(abierta)
  montoApertura Decimal          @map("monto_apertura") @db.Decimal(12, 2)
  montoCierre   Decimal?         @map("monto_cierre") @db.Decimal(12, 2)
  montoEsperado Decimal?         @map("monto_esperado") @db.Decimal(12, 2)
  diferencia    Decimal?         @db.Decimal(12, 2)
  notasApertura String?          @map("notas_apertura") @db.Text
  notasCierre   String?          @map("notas_cierre") @db.Text
  abiertaEn     DateTime         @default(now()) @map("abierta_en")
  cerradaEn     DateTime?        @map("cerrada_en")

  ventas      Venta[]
  movimientos MovimientoCaja[]

  @@index([sucursalId, abiertaEn])
  @@map("sesiones_caja")
}

enum TipoMovimientoCaja {
  ingreso
  egreso
  retiro
  ajuste

  @@map("tipo_movimiento_caja")
}

enum CategoriaMovimientoCaja {
  // Ingresos
  saldo_anterior
  adelanto_cliente
  cobro_credito
  devolucion_proveedor
  otro_ingreso
  // Egresos
  pago_proveedor
  servicio_basico
  comision_empleado
  refrigerio
  movilidad
  publicidad
  devolucion_cliente
  otro_egreso

  @@map("categoria_movimiento_caja")
}

enum TipoContraparte {
  cliente
  proveedor
  empleado
  otro

  @@map("tipo_contraparte")
}

model MovimientoCaja {
  id                    String                   @id @default(uuid()) @db.Uuid
  sesionId              String                   @map("sesion_id") @db.Uuid
  sesion                SesionCaja               @relation(fields: [sesionId], references: [id])
  tipo                  TipoMovimientoCaja
  categoria             CategoriaMovimientoCaja? @default(otro_ingreso)
  subCategoria          String?                  @map("sub_categoria") @db.VarChar(40)
  medio                 MedioPago                @default(efectivo)
  monto                 Decimal                  @db.Decimal(12, 2)
  motivo                String                   @db.VarChar(240)
  comprobante           String?                  @db.VarChar(60)
  contraparte           String?                  @db.VarChar(180)
  contraparteTipo       TipoContraparte?         @map("contraparte_tipo")
  contraparteId         String?                  @map("contraparte_id") @db.Uuid
  contraparteDocumento  String?                  @map("contraparte_documento") @db.VarChar(20)
  creadoPorId           String?                  @map("creado_por_id") @db.Uuid
  creadoPor             Usuario?                 @relation("MovimientosCajaCreados", fields: [creadoPorId], references: [id])
  creadoEn              DateTime                 @default(now()) @map("creado_en")
  eliminadoEn           DateTime?                @map("eliminado_en")

  @@index([sesionId, creadoEn])
  @@index([sesionId, tipo])
  @@index([sesionId, categoria])
  @@map("movimientos_caja")
}

model AuditLog {
  id        BigInt   @id @default(autoincrement())
  modulo    String   @db.VarChar(40)
