{
  "name": "@ropas/backend",
  "version": "0.0.1",
  "private": true,
  "description": "API NestJS multi-tenant de Ropas",
  "scripts": {
    "predev": "node scripts/kill-puerto.mjs 3001 && prisma generate",
    "build": "nest build",
    "dev": "nest start --watch",
    "kill-puerto": "node scripts/kill-puerto.mjs",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:format": "prisma format",
    "schema:snapshot": "tsx scripts/generar-snapshot-schema.ts",
    "tenant:crear": "tsx scripts/crear-tenant.ts",
    "tenant:migrar": "tsx scripts/migrar-tenants.ts",
    "tenant:modulo": "tsx scripts/tenant-modulo.ts",
    "tenant:plan": "tsx scripts/tenant-plan.ts",
    "seed": "tsx scripts/seed-demo.ts",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "seed:productos": "tsx scripts/seed-productos-10.ts",
    "seed:mujer": "tsx scripts/seed-mujer.ts",
    "seed:ventas": "tsx scripts/seed-ventas.ts",
    "seed:proveedores": "tsx scripts/seed-proveedores.ts",
    "migrar:codigo": "tsx scripts/aplicar-migracion-codigo.ts",
    "migrar:codigo-entidades": "tsx scripts/aplicar-migracion-codigo-entidades.ts",
    "migrar:clasificacion-clientes": "tsx scripts/aplicar-migracion-clasificacion-clientes.ts",
    "migrar:cupones": "tsx scripts/aplicar-migracion-cupones.ts",
    "migrar:cupones-temas": "tsx scripts/aplicar-migracion-cupones-temas.ts",
    "migrar:venta-item-costo": "tsx scripts/aplicar-migracion-venta-item-costo.ts",
    "migrar:drop-opciones-retorno": "tsx scripts/aplicar-migracion-drop-opciones-retorno.ts",
    "setup:facturacion": "tsx scripts/setup-facturacion.ts",
    "facturacion:master-key": "tsx scripts/generar-master-key-facturacion.ts"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "@napi-rs/canvas": "^1.0.0",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.0.7",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.7",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.7",
    "@nestjs/schedule": "^6.0.0",
    "@prisma/client": "^6.2.1",
    "@types/multer": "^2.1.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.0.0",
    "lru-cache": "^11.0.2",
    "nestjs-pino": "^4.4.0",
    "pdfkit": "^0.18.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.2.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.2",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "prisma",
      "@prisma/engines"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "ts",
      "json"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
