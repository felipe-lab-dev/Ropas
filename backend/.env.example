# Servidor
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Base de datos
DATABASE_URL="postgresql://ropas_admin:CHANGE_ME@localhost:5432/ropas?schema=public"
TENANT_TEMPLATE_SCHEMA="tenant_template"

# JWT (auth interna del producto)
JWT_SECRET="cambiar-en-produccion-minimo-32-chars"
JWT_REFRESH_SECRET="cambiar-en-produccion-otro-secreto"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Integración con ENKI (portal SaaS)
ENKI_BASE_URL="https://enki.midominio.com"
ENKI_API_KEY="enki_live_xxxxxxxxxxxxxxxxxxxxxxxx"
ENKI_TENANT_CODE="mi-tienda"
ENKI_SISTEMA_ID="uuid-en-enki"
ENKI_HEARTBEAT_INTERVAL_MS=300000
# En dev local sin ENKI corriendo:
ENKI_OFFLINE=true

# CORS
CORS_ORIGIN="http://localhost:3000"
