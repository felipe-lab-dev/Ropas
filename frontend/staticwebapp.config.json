{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/_next/*", "/static/*", "*.{css,scss,js,png,gif,ico,jpg,svg,woff,woff2,ttf,eot,otf,webp,avif}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  }
}
